# Maps JavaScript API key (enable Maps JavaScript API in Google Cloud; restrict by HTTP referrer in production).
VITE_GOOGLE_MAPS_API_KEY=

# Supabase shared datastore (public frontend config). Create the app_state table with scripts/supabase-app-state.sql.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
